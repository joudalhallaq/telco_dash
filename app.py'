    "import pandas as pd\n",
    "import plotly.express as px\n",
    "from dash import Dash, dcc, html, Input, Output\n",
    "\n",
    "df = pd.read_csv(\"WA_Fn-UseC_-Telco-Customer-Churn.csv\")\n",
    "\n",
    "df[\"TotalCharges\"] = pd.to_numeric(df[\"TotalCharges\"], errors=\"coerce\")\n",
    "df.dropna(inplace=True)\n",
    "\n",
    "app = Dash(__name__)\n",
    "server = app.server\n",
    "\n",
    "app.layout = html.Div(\n",
    "    style={\"fontFamily\": \"Arial\", \"padding\": \"25px\", \"backgroundColor\": \"#f7f9fc\"},\n",
    "    children=[\n",
    "        html.H1(\n",
    "            \"Telco Customer Churn Dashboard\",\n",
    "            style={\"textAlign\": \"center\", \"color\": \"#1f3c88\"}\n",
    "        ),\n",
    "\n",
    "        html.P(\n",
    "            \"Interactive dashboard for analyzing customer churn based on contract type.\",\n",
    "            style={\"textAlign\": \"center\"}\n",
    "        ),\n",
    "\n",
    "        html.Label(\"Select Contract Type:\", style={\"fontWeight\": \"bold\"}),\n",
    "\n",
    "        dcc.Dropdown(\n",
    "            id=\"contract_filter\",\n",
    "            options=[{\"label\": c, \"value\": c} for c in sorted(df[\"Contract\"].unique())],\n",
    "            value=sorted(df[\"Contract\"].unique())[0],\n",
    "            clearable=False,\n",
    "            style={\"width\": \"50%\", \"marginBottom\": \"25px\"}\n",
    "        ),\n",
    "\n",
    "        dcc.Graph(id=\"churn_chart\"),\n",
    "        dcc.Graph(id=\"charges_chart\")\n",
    "    ]\n",
    ")\n",
    "\n",
    "@app.callback(\n",
    "    [Output(\"churn_chart\", \"figure\"), Output(\"charges_chart\", \"figure\")],\n",
    "    Input(\"contract_filter\", \"value\")\n",
    ")\n",
    "def update_charts(selected_contract):\n",
    "    filtered_df = df[df[\"Contract\"] == selected_contract]\n",
    "\n",
    "    fig1 = px.histogram(\n",
    "        filtered_df,\n",
    "        x=\"Churn\",\n",
    "        color=\"Churn\",\n",
    "        title=f\"Churn Distribution for {selected_contract} Contract\",\n",
    "        labels={\"Churn\": \"Customer Churn\"}\n",
    "    )\n",
    "\n",
    "    fig1.update_layout(\n",
    "        xaxis_title=\"Churn\",\n",
    "        yaxis_title=\"Number of Customers\",\n",
    "        title_x=0.5\n",
    "    )\n",
    "\n",
    "    fig2 = px.scatter(\n",
    "        filtered_df,\n",
    "        x=\"MonthlyCharges\",\n",
    "        y=\"TotalCharges\",\n",
    "        color=\"Churn\",\n",
    "        size=\"tenure\",\n",
    "        hover_data=[\"gender\", \"SeniorCitizen\", \"PaymentMethod\", \"InternetService\"],\n",
    "        title=f\"Monthly Charges vs Total Charges for {selected_contract} Contract\"\n",
    "    )\n",
    "\n",
    "    fig2.update_layout(\n",
    "        xaxis_title=\"Monthly Charges\",\n",
    "        yaxis_title=\"Total Charges\",\n",
    "        title_x=0.5\n",
    "    )\n",
    "\n",
    "    return fig1, fig2\n",
    "\n",
    "if __name__ == \"__main__\":\n",
    "    app.run(debug=True, port=8051)"
   ]
